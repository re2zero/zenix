#!/usr/bin/make -f
%:
	dh $@

override_dh_auto_build:
	export HOME=$(CURDIR)/debian/build-home && mkdir -p $$HOME/.cargo && \
	cp $(CURDIR)/debian/cargo-config.toml $$HOME/.cargo/config.toml && \
	cargo build --release

override_dh_auto_install:
	install -D -m 0755 target/release/deepin-herdr debian/deepin-herdr/usr/bin/deepin-herdr

override_dh_auto_clean:
	rm -rf target

override_dh_shlibdeps:
	dh_shlibdeps -l$(CURDIR)/debian/deepin-herdr/usr/lib/x86_64-linux-gnu
